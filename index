                        </ul>
                        <div class="price-note">
                            ⚡ Соглашение о неразглашении (NDA) строго соблюдается — данные предоставляются только по запросу клиента.
                        </div>
                    </div>
                    <div class="form-fields">
                        <form id="leadForm">
                            <div class="input-group">
                                <input type="text" id="companyName" name="company" placeholder="Название организации" required>
